{
  "expo": {
    "name": "GiftHighway",
    "slug": "company-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "companyapp",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F0914A"
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gifthighway"
    },
    "android": {
      "package": "com.gifthighway",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F0914A"
      },
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#6366F1",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-share-intent",
        {
          "iosActivationRules": {
            "NSExtensionActivationSupportsFileWithMaxCount": 10,
            "NSExtensionActivationSupportsImageWithMaxCount": 10
          },
          "androidIntentFilters": [
            "*/*"
          ],
          "androidMainActivityAttributes": {
            "android:launchMode": "singleTask"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "0c56871c-426a-4053-896e-173a2b316648"
      }
    },
    "owner": "gift-highway"
  }
}
