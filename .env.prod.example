# ── Domain ────────────────────────────────────────────────────────────────────
DOMAIN=app.yourdomain.com
MONITOR_DOMAIN=monitor.yourdomain.com
ACME_EMAIL=you@yourdomain.com

# ── Monitor basic auth (generate with: htpasswd -nb admin yourpassword) ───────
ADMIN_AUTH=admin:$$apr1$$xxxxxxxx$$xxxxxxxxxxxxxxxxxxxxxxxx

# ── Cloudflare (for Let's Encrypt DNS challenge) ──────────────────────────────
CF_API_TOKEN=your-cloudflare-api-token

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=appdb
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me-strong-password

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-32-chars-min
JWT_EXPIRY=15m
REFRESH_EXPIRY=720h

# ── Cloudflare R2 storage (file uploads + DB backups) ────────────────────────
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY=your-access-key
R2_SECRET_KEY=your-secret-key
R2_BUCKET=your-bucket-name
R2_PUBLIC_URL=https://your-bucket.r2.dev
# R2_ENDPOINT is auto-derived from R2_ACCOUNT_ID by backup scripts — no need to set manually

# ── Expo Push Notifications ───────────────────────────────────────────────────
# Optional — leave blank to use the unauthenticated Expo push API (rate-limited to ~1000/hr).
# Required for higher volume. Get yours at:
#   https://expo.dev/accounts/[your-account]/settings/access-tokens
EXPO_ACCESS_TOKEN=
