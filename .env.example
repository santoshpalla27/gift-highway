# Backend
APP_ENV=development
PORT=8080
DATABASE_URL=postgres://app:secret@localhost:5432/appdb?sslmode=disable
JWT_SECRET=change-me-in-production-use-32-chars-minimum
JWT_EXPIRY=15m
REFRESH_EXPIRY=720h
ALLOWED_ORIGINS=http://localhost:5173

# Frontend
VITE_API_URL=/api/v1

# Mobile
EXPO_PUBLIC_API_URL=http://localhost:8080/api/v1

# Push notifications (optional — only needed in prod/staging docker-compose)
# EXPO_ACCESS_TOKEN=your-expo-access-token
