# ── Backend ───────────────────────────────────────────────────────────────────
APP_ENV=development
PORT=8080
DATABASE_URL=postgres://app:secret@localhost:5432/appdb?sslmode=disable
JWT_SECRET=change-me-in-production-use-32-chars-minimum
JWT_EXPIRY=15m
REFRESH_EXPIRY=720h
ALLOWED_ORIGINS=http://localhost:5173
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=200

# ── Database (used by docker-compose) ─────────────────────────────────────────
POSTGRES_DB=appdb
POSTGRES_USER=app
POSTGRES_PASSWORD=secret

# ── Cloudflare R2 (file storage) ──────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=app-data
R2_PUBLIC_URL=https://<account_id>.r2.cloudflarestorage.com/<bucket>

# ── Audit / backup (optional — leave blank to disable) ────────────────────────
AUDIT_R2_BUCKET=
SMTP_USER=gifthighway.audit@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
AUDIT_EMAIL_TO=youremail@gmail.com

# ── Push notifications (optional) ─────────────────────────────────────────────
EXPO_ACCESS_TOKEN=

# ── Production / reverse proxy (used by docker-compose.yml) ───────────────────
DOMAIN=yourdomain.com
MONITOR_DOMAIN=monitor.yourdomain.com
ACME_EMAIL=youremail@gmail.com
ADMIN_AUTH=admin:$$2y$$...   # htpasswd-hashed password for monitor basic auth
CF_API_TOKEN=                 # Cloudflare API token for DNS challenge (if used)
LOG_FORMAT=json

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=/api/v1

# ── Mobile ────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:8080/api/v1
