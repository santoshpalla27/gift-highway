# GiftHighway backup scripts — required environment variables
# Copy to .env or .env.prod in this directory:
#   cp .env.example .env.prod

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=kanban
POSTGRES_DB=appdb

# ── Cloudflare R2 (secondary backup — hourly) ─────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=

# ── AWS S3 (primary backup — every 5 minutes) ─────────────────────────────────
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_BUCKET=
