# ── Domain ────────────────────────────────────────────────────────────────────
# Use a different subdomain from prod so both can run on the same server
DOMAIN=staging.yourdomain.com
ACME_EMAIL=you@yourdomain.com

# ── Cloudflare (for Let's Encrypt DNS challenge) ──────────────────────────────
CF_API_TOKEN=your-cloudflare-api-token

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=appdb_staging
POSTGRES_USER=app
POSTGRES_PASSWORD=staging-secret

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=staging-jwt-secret-change-me-32chars
JWT_EXPIRY=15m
REFRESH_EXPIRY=720h

# ── Cloudflare R2 storage (optional for staging) ─────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# ── Expo Push Notifications (optional for staging) ───────────────────────────
EXPO_ACCESS_TOKEN=
