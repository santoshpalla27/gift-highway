# API base URL
# Dev (Vite proxy):    /api/v1
# Production:          https://api.yourdomain.com/api/v1
VITE_API_URL=/api/v1

# WebSocket URL (optional — auto-derived from window.location if omitted)
# Dev (Vite proxy):    omit or ws://localhost:5173/ws
# Production:          wss://api.yourdomain.com/ws
# VITE_WS_URL=wss://api.yourdomain.com/ws
