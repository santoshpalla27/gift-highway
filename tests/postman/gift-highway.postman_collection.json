{
  "info": {
    "name": "Gift Highway API",
    "_postman_id": "gift-highway-api-collection",
    "description": "Complete API collection for Gift Highway backend.\nIncludes all endpoints grouped by area: Auth, Orders, Timeline, Notifications, Admin, Portal.\n\nSetup:\n1. Set {{base_url}} to your backend URL (default: http://localhost:8080)\n2. Login via Auth > Login to auto-populate {{admin_token}}",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" },
    { "key": "admin_token", "value": "" },
    { "key": "member_token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "order_id", "value": "bbbb0001-bbbb-bbbb-bbbb-bbbbbbbbbbbb" },
    { "key": "user_id", "value": "" },
    { "key": "event_id", "value": "" },
    { "key": "portal_token", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var data = pm.response.json();",
                  "  pm.collectionVariables.set('admin_token', data.tokens.access_token);",
                  "  pm.collectionVariables.set('refresh_token', data.tokens.refresh_token);",
                  "  pm.test('Login successful', function() { pm.response.to.have.status(200); });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"admin@company.com\", \"password\": \"Admin@123456\"}"
            }
          }
        },
        {
          "name": "Login (Member)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var data = pm.response.json();",
                  "  pm.collectionVariables.set('member_token', data.tokens.access_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"sarah@giftco.com\", \"password\": \"Admin@123456\"}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/refresh",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"refresh_token\": \"{{refresh_token}}\"}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/logout",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ]
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/auth/me",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/orders?page=1&limit=20",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ]
          }
        },
        {
          "name": "Create Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('order_id', pm.response.json().order.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/orders",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"Postman Test Order\", \"customer_name\": \"Postman Customer\", \"priority\": \"medium\", \"description\": \"Created via Postman\"}"
            }
          }
        },
        {
          "name": "Get Order",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/orders/{{order_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ]
          }
        },
        {
          "name": "Update Order",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/v1/orders/{{order_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"Updated Title\", \"customer_name\": \"Updated Customer\", \"priority\": \"high\", \"assigned_to\": []}"
            }
          }
        },
        {
          "name": "Update Status",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/v1/orders/{{order_id}}/status",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"status\": \"in_progress\"}"
            }
          }
        },
        {
          "name": "Archive Order",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/orders/{{order_id}}/archive",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ]
          }
        },
        {
          "name": "List Trash",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/orders/trash",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ]
          }
        },
        {
          "name": "Restore Order",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/orders/{{order_id}}/restore",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ]
          }
        },
        {
          "name": "Permanent Delete",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/v1/orders/{{order_id}}/permanent",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Timeline",
      "item": [
        {
          "name": "List Events",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/orders/{{order_id}}/events",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ]
          }
        },
        {
          "name": "Add Comment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('event_id', pm.response.json().event.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/orders/{{order_id}}/comments",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"text\": \"Postman test comment\"}"
            }
          }
        },
        {
          "name": "Edit Comment",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/v1/orders/{{order_id}}/events/{{event_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"text\": \"Edited via Postman\"}"
            }
          }
        },
        {
          "name": "Delete Comment",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/v1/orders/{{order_id}}/events/{{event_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ]
          }
        },
        {
          "name": "Get Upload URL",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/orders/{{order_id}}/attachments/upload-url",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"file_name\": \"test.jpg\", \"mime_type\": \"image/jpeg\", \"size_bytes\": 1024}"
            }
          }
        },
        {
          "name": "List Attachments",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/orders/{{order_id}}/attachments",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Get Unread",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/notifications",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ]
          }
        },
        {
          "name": "Get Activity",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/notifications/activity",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ]
          }
        },
        {
          "name": "Get History",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/notifications/history",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ]
          }
        },
        {
          "name": "Get Order Summaries",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/notifications/orders",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ]
          }
        },
        {
          "name": "Get Order Notifications",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/notifications/order/{{order_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ]
          }
        },
        {
          "name": "Mark Order Read",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/notifications/read/{{order_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ]
          }
        },
        {
          "name": "Mark All Read",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/notifications/read-all",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/admin/users",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ]
          }
        },
        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('user_id', pm.response.json().user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/admin/users",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Postman User\", \"email\": \"postman@test.local\", \"password\": \"Postman@1234\", \"role\": \"user\"}"
            }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/v1/admin/users/{{user_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Updated Postman User\", \"email\": \"postman@test.local\", \"role\": \"user\"}"
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/v1/admin/users/{{user_id}}/password",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"password\": \"NewPostman@1234\"}"
            }
          }
        },
        {
          "name": "Disable User",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/v1/admin/users/{{user_id}}/disable",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ]
          }
        },
        {
          "name": "Enable User",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/v1/admin/users/{{user_id}}/enable",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ]
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/v1/admin/users/{{user_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Portal (Public)",
      "item": [
        {
          "name": "Get Portal",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/portal/{{portal_token}}"
          }
        },
        {
          "name": "Get Messages",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/portal/{{portal_token}}/messages"
          }
        },
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/portal/{{portal_token}}/messages",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"text\": \"Customer message via Postman\"}"
            }
          }
        },
        {
          "name": "Get Attachments",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/portal/{{portal_token}}/attachments"
          }
        }
      ]
    }
  ]
}
